{
  "manifest_version": 3,
  "name": "YouTube Dabing CZ",
  "version": "0.8.1",
  "description": "Přehrává titulky YouTube videa nahlas v češtině (nebo jiném jazyce) – dabing přes překlad titulků a hlas prohlížeče.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://*.tts.speech.microsoft.com/*",
    "https://api.elevenlabs.io/*",
    "https://www.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "src/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "YouTube Dabing CZ"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/inject.js"
      ],
      "matches": [
        "https://www.youtube.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  }
}